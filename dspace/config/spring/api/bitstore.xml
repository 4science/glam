<?xml version="1.0" encoding="UTF-8" ?>
<beans
    xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd"
    default-lazy-init="true"
>

    <bean
        name="org.dspace.storage.bitstore.BitstreamStorageService"
        class="org.dspace.storage.bitstore.BitstreamStorageServiceImpl"
    >
        <property name="incoming" value="${assetstore.index.primary}" />
        <property name="stores">
            <map>
                <entry key="0" value-ref="localStore"/>
                <entry key="1" value-ref="s3Store"/>
                <entry key="10" value-ref="s3TempStore"/>
            </map>
        </property>
    </bean>

    <bean
        name="localStore"
        class="org.dspace.storage.bitstore.DSBitStoreService"
        scope="singleton"
    >
        <property name="baseDir" value="${assetstore.dir}" />
    </bean>

    <bean
        name="s3Store"
        class="org.dspace.storage.bitstore.S3BitStoreService"
        scope="singleton"
        lazy-init="true"
    >
        <property name="enabled" value="${assetstore.s3.enabled}" />
        <!-- AWS Security credentials, with policies for specified bucket -->
        <property name="awsAuthenticationType" value="${assetstore.s3.awsAuthenticationType}" />
        <property name="awsAccessKey" value="${assetstore.s3.awsAccessKey}" />
        <property name="awsSecretKey" value="${assetstore.s3.awsSecretKey}" />
        <property name="awsSessionToken" value="${assetstore.s3.awsToken}" />
        <property name="useRelativePath" value="${assetstore.s3.useRelativePath}" />

        <!-- S3 bucket name to store assets in. example: longsight-dspace-auk -->
        <property name="bucketName" value="${assetstore.s3.bucketName}" />

        <!-- AWS S3 Region to use: {us-east-1, us-west-1, eu-west-1, eu-central-1, ap-southeast-1, ... } -->
        <!-- Optional, sdk default is us-east-1 -->
        <property name="awsRegionName" value="${assetstore.s3.awsRegionName}" />

        <!-- STS (Security Token Service) Configuration -->
        <!-- Only used when awsAuthenticationType is set to "sts" -->
        <property name="stsRoleArn" value="${assetstore.s3.stsRoleArn}" />
        <property
            name="stsSessionName"
            value="${assetstore.s3.stsSessionName}"
        />
        <property
            name="stsSessionDuration"
            value="${assetstore.s3.stsSessionDuration}"
        />
        <property name="stsExternalId" value="${assetstore.s3.stsExternalId}" />
        <property name="stsEndpoint" value="${assetstore.s3.stsEndpoint}" />
        <property name="stsRegion" value="${assetstore.s3.stsRegion}" />

        <!-- Subfolder to organize assets within the bucket, in case this bucket is shared  -->
        <!-- Optional, default is root level of bucket -->
        <property name="subfolder" value="${assetstore.s3.subfolder}" />
        <property
            name="maxConnections"
            value="${assetstore.s3.maxConnections}"
        />
        <property
            name="connectionTimeout"
            value="${assetstore.s3.connectionTimeout}"
        />
        <property name="endpoint" value="${assetstore.s3.endpoint}" />
    </bean>

    <bean name="s3TempStore" class="org.dspace.storage.bitstore.S3BitStoreService" scope="singleton" lazy-init="true">
        <!-- AWS Security credentials, with policies for specified bucket -->
        <property name="awsAuthenticationType" value="${assetstore.s3.awsAuthenticationType}" />
        <property name="awsAccessKey" value="${assetstore.s3.awsAccessKey}" />
        <property name="awsSecretKey" value="${assetstore.s3.awsSecretKey}" />
        <property name="awsSessionToken" value="${assetstore.s3.awsToken}" />
        <property name="useRelativePath" value="${assetstore.s3.useRelativePath}" />

        <!-- S3 bucket name to store assets in. example: longsight-dspace-auk -->
        <property name="bucketName" value="${assetstore.s3.bucketName}" />

        <!-- AWS S3 Region to use: {us-east-1, us-west-1, eu-west-1, eu-central-1, ap-southeast-1, ... } -->
        <!-- Optional, sdk default is us-east-1 -->
        <property name="awsRegionName" value="${assetstore.s3.awsRegionName}" />

        <!-- STS (Security Token Service) Configuration -->
        <!-- Only used when awsAuthenticationType is set to "sts" -->
        <property name="stsRoleArn" value="${assetstore.s3.stsRoleArn}" />
        <property
                name="stsSessionName"
                value="${assetstore.s3.stsSessionName}"
        />
        <property
                name="stsSessionDuration"
                value="${assetstore.s3.stsSessionDuration}"
        />
        <property name="stsExternalId" value="${assetstore.s3.stsExternalId}" />
        <property name="stsEndpoint" value="${assetstore.s3.stsEndpoint}" />
        <property name="stsRegion" value="${assetstore.s3.stsRegion}" />

        <!-- Subfolder to organize assets within the bucket, in case this bucket is shared  -->
        <!-- Optional, default is root level of bucket -->
        <property name="subfolder" value="${assetstore.s3.subfolder}" />
        <property
                name="maxConnections"
                value="${assetstore.s3.maxConnections}"
        />
        <property
                name="connectionTimeout"
                value="${assetstore.s3.connectionTimeout}"
        />
        <property name="endpoint" value="${assetstore.s3.endpoint}" />
    </bean>

    <!-- <bean name="localStore2 ... -->
    <!-- <bean name="s3Store2 ... -->
</beans>
