<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:util="http://www.springframework.org/schema/util"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans-2.5.xsd
                           http://www.springframework.org/schema/context
                           http://www.springframework.org/schema/context/spring-context-2.5.xsd
                           http://www.springframework.org/schema/util
                           http://www.springframework.org/schema/util/spring-util.xsd"
       default-autowire-candidates="*Service,*DAO,javax.sql.DataSource">

    <context:annotation-config/>
    <!-- allows us to use spring annotations in beans -->

    <bean class="org.dspace.curate.service.S3FileChecker" id="org.dspace.curate.service.S3FileChecker">
        <property name="delayTimeUnit" value="${curation.s3.delayTimeUnit}"/>
        <property name="delayBetweenAttempts" value="${curation.s3.delayBetweenAttempts}"/>
        <property name="globalTimeoutUnit" value="${curation.s3.globalTimeoutUnit}"/>
        <property name="globalTimeoutDuration" value="${curation.s3.globalTimeoutDuration}"/>
        <property name="useExponentialBackoff" value="${curation.s3.useExponentialBackoff}"/>
    </bean>

    <bean class="org.dspace.curate.CurationTaskResolverServiceImpl">
        <property name="serverlessCurationTasks" ref="serverlessCurationTasks" />
    </bean>

    <util:list id="serverlessCurationTasks">
        <ref bean="pdfACurationTask"/>
    </util:list>

    <!-- Serverless Curation task beans -->
    <bean id="pdfACurationTask" class="org.dspace.ctask.general.PdfACurationTask" />

</beans>