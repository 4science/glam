<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context.xsd"
       default-autowire-candidates="*Service,*DAO,javax.sql.DataSource">

    <context:annotation-config /> <!-- allows us to use spring annotations in beans -->

    <bean id="solrAdminServiceFactory" class="org.dspace.solr.SolrAdminServiceFactory"
          autowire-candidate="true"/>
    <bean id="standaloneStatisticsSolrAdminService" class="org.dspace.solr.StandaloneStatisticsSolrAdminService"
          autowire-candidate="true"/>
    <bean id="cloudStatisticsSolrAdminService" class="org.dspace.solr.CloudStatisticsSolrAdminService"
          autowire-candidate="true"/>

    <!-- ========== VALIDATION QUERIES ========== -->

    <!-- Discovery validation query -->
    <bean id="discoveryValidationQuery" class="org.dspace.solr.SolrValidationQuery">
        <constructor-arg value="*:*" /> <!-- query -->
        <constructor-arg> <!-- filterQueries -->
            <array>
                <value>search.resourcetype:Item</value>
                <value>search.resourceid:1</value>
            </array>
        </constructor-arg>
        <constructor-arg> <!-- fields -->
            <array>
                <value>search.resourcetype</value>
                <value>search.resourceid</value>
            </array>
        </constructor-arg>
        <constructor-arg value="0" /> <!-- rows -->
    </bean>

    <!-- Simple ping validation query for most services -->
    <bean id="simplePingValidationQuery" class="org.dspace.solr.SolrValidationQuery">
        <constructor-arg value="*:*" /> <!-- query -->
        <constructor-arg><null/></constructor-arg> <!-- filterQueries -->
        <constructor-arg><null/></constructor-arg> <!-- fields -->
        <constructor-arg value="0" /> <!-- rows -->
    </bean>

    <!-- Deduplication validation query -->
    <bean id="dedupValidationQuery" class="org.dspace.solr.SolrValidationQuery">
        <constructor-arg value="*:*" /> <!-- query -->
        <constructor-arg>
            <array>
                <value>dedup.resourcetype:2</value>
                <value>dedup.id:1</value>
            </array>
        </constructor-arg> <!-- filterQueries -->
        <constructor-arg> <!-- fields -->
            <array>
                <value>dedup.resourcetype</value>
                <value>dedup.id</value>
            </array>
        </constructor-arg>
        <constructor-arg value="0" /> <!-- rows -->
    </bean>

    <!-- ========== VALIDATORS ========== -->

    <!-- Discovery validator -->
    <bean id="discoveryValidator" class="org.dspace.solr.SolrClientValidator">
        <constructor-arg ref="org.dspace.services.ConfigurationService" />
        <constructor-arg ref="discoveryValidationQuery" />
        <constructor-arg value="discovery.solr.url.validation.enabled" />
    </bean>

    <!-- Audit validator -->
    <bean id="auditValidator" class="org.dspace.solr.SolrClientValidator">
        <constructor-arg ref="org.dspace.services.ConfigurationService" />
        <constructor-arg ref="simplePingValidationQuery" />
        <constructor-arg value="audit.solr.url.validation.enabled" />
    </bean>

    <!-- Authority validator -->
    <bean id="authorityValidator" class="org.dspace.solr.SolrClientValidator">
        <constructor-arg ref="org.dspace.services.ConfigurationService" />
        <constructor-arg ref="simplePingValidationQuery" />
        <constructor-arg value="authority.solr.url.validation.enabled" />
    </bean>

    <!-- OCR/IIIF validator -->
    <bean id="iiifValidator" class="org.dspace.solr.SolrClientValidator">
        <constructor-arg ref="org.dspace.services.ConfigurationService" />
        <constructor-arg ref="simplePingValidationQuery" />
        <constructor-arg value="iiif.solr.url.validation.enabled" />
    </bean>

    <!-- Deduplication validator -->
    <bean id="dedupValidator" class="org.dspace.solr.SolrClientValidator">
        <constructor-arg ref="org.dspace.services.ConfigurationService" />
        <constructor-arg ref="dedupValidationQuery" />
        <constructor-arg value="deduplication.solr.url.validation.enabled" />
    </bean>

    <!-- Suggestion validator -->
    <bean id="suggestionValidator" class="org.dspace.solr.SolrClientValidator">
        <constructor-arg ref="org.dspace.services.ConfigurationService" />
        <constructor-arg ref="simplePingValidationQuery" />
        <constructor-arg value="suggestion.solr.url.validation.enabled" />
    </bean>

    <!-- ========== VALIDATOR FACTORIES ========== -->

    <!-- Discovery validator factory (extends base class with custom setup) -->
    <bean id="searchValidatorSolrClientCoreFactory"
          class="org.dspace.discovery.SearchValidatorSolrClientCoreFactory">
        <constructor-arg ref="baseHttpSolrClientFactory" />
        <constructor-arg ref="org.dspace.services.ConfigurationService" />
        <constructor-arg ref="org.dspace.discovery.IndexingService" />
        <constructor-arg ref="discoveryValidator" />
    </bean>

    <!-- Simple validator factories (use base class directly) -->

    <bean id="auditValidatorSolrClientFactory"
          class="org.dspace.solr.BaseValidatingSolrClientFactory">
        <constructor-arg ref="baseHttpSolrClientFactory"/>
        <constructor-arg ref="org.dspace.services.ConfigurationService"/>
        <constructor-arg ref="auditValidator"/>
        <constructor-arg value="Audit"/>
    </bean>

    <bean id="authorityValidatorSolrClientFactory"
          class="org.dspace.solr.BaseValidatingSolrClientFactory">
        <constructor-arg ref="baseHttpSolrClientFactory"/>
        <constructor-arg ref="org.dspace.services.ConfigurationService"/>
        <constructor-arg ref="authorityValidator"/>
        <constructor-arg value="Authority"/>
    </bean>

    <bean id="ocrValidatorSolrClientFactory"
          class="org.dspace.solr.BaseValidatingSolrClientFactory">
        <constructor-arg ref="baseHttpSolrClientFactory" />
        <constructor-arg ref="org.dspace.services.ConfigurationService" />
        <constructor-arg ref="iiifValidator" />
        <constructor-arg value="IIIF" />
    </bean>

    <bean id="dedupValidatorSolrClientFactory"
          class="org.dspace.solr.BaseValidatingSolrClientFactory">
        <constructor-arg ref="baseHttpSolrClientFactory"/>
        <constructor-arg ref="org.dspace.services.ConfigurationService"/>
        <constructor-arg ref="dedupValidator"/>
        <constructor-arg value="Deduplication"/>
    </bean>

    <bean id="suggestionValidatorSolrClientFactory"
          class="org.dspace.solr.BaseValidatingSolrClientFactory">
        <constructor-arg ref="baseHttpSolrClientFactory"/>
        <constructor-arg ref="org.dspace.services.ConfigurationService"/>
        <constructor-arg ref="suggestionValidator"/>
        <constructor-arg value="Suggestion"/>
    </bean>

    <!-- ========== CLOUD-ENABLED DECORATORS ========== -->

    <!-- Cloud-enabled decorator for search -->
    <bean id="searchSolrClientFactory"
          class="org.dspace.solr.SolrCloudClientFactoryDecorator" autowire-candidate="true">
        <constructor-arg ref="searchValidatorSolrClientCoreFactory"/>
        <constructor-arg value="search.uniqueid"/>
    </bean>

    <!-- Base HTTP factory -->
    <bean id="baseHttpSolrClientFactory" class="org.dspace.solr.HttpSolrClientFactory"/>

    <!-- Decorator wraps SolrCloud with SolrCloudClientDecorator -->
    <bean id="statisticsClientFactory" class="org.dspace.solr.SolrCloudClientFactoryDecorator" autowire-candidate="true">
        <constructor-arg ref="baseHttpSolrClientFactory"/>
        <constructor-arg value="uid"/>
    </bean>

    <!-- Other services with cloud support -->
    <bean id="auditSolrClientFactory" class="org.dspace.solr.SolrCloudClientFactoryDecorator" autowire-candidate="true">
        <constructor-arg ref="auditValidatorSolrClientFactory"/>
        <constructor-arg value="uid"/>
    </bean>

    <bean id="authoritySolrClientFactory" class="org.dspace.solr.SolrCloudClientFactoryDecorator" autowire-candidate="true">
        <constructor-arg ref="authorityValidatorSolrClientFactory"/>
        <constructor-arg value="id"/>
    </bean>

    <bean id="ocrSolrClientFactory"
          class="org.dspace.solr.SolrCloudClientFactoryDecorator" autowire-candidate="true">
        <constructor-arg ref="ocrValidatorSolrClientFactory" />
        <constructor-arg value="id" />
    </bean>

    <bean id="dedupSolrClientFactory" class="org.dspace.solr.SolrCloudClientFactoryDecorator" autowire-candidate="true">
        <constructor-arg ref="dedupValidatorSolrClientFactory"/>
        <constructor-arg value="dedup.uniqueid"/>
    </bean>

    <bean id="suggestionSolrClientFactory" class="org.dspace.solr.SolrCloudClientFactoryDecorator" autowire-candidate="true">
        <constructor-arg ref="suggestionValidatorSolrClientFactory"/>
        <constructor-arg value="suggestion_fullid"/>
    </bean>

    <!-- ========== SERVICE BEANS ========== -->

    <bean class="org.dspace.discovery.SolrSearchCore" autowire-candidate="true"/>
    <bean class="org.dspace.discovery.SolrServiceImpl" id="org.dspace.discovery.SearchService"/>
    <alias name="org.dspace.discovery.SearchService" alias="org.dspace.discovery.IndexingService"/>

    <bean id="solrLoggerService"
          class="org.dspace.statistics.SolrLoggerServiceImpl"
          lazy-init="true">
        <description>Store and access DSpace usage statistics records in Solr.</description>
    </bean>

    <bean id='solrStatisticsCore'
          class='org.dspace.statistics.SolrStatisticsCore'
          autowire-candidate='true'>
        <description>Store and access DSpace usage statistics records in Solr.</description>
        <property name="solrClientFactory" ref="statisticsClientFactory"/>
    </bean>

    <!-- quality assurance broker service -->
    <bean id="org.dspace.qaevent.service.QAEventService" class="org.dspace.qaevent.service.impl.QAEventServiceImpl" />

    <bean id="qaeventSolrClientFactory" class="org.dspace.solr.SolrCloudClientFactoryDecorator" autowire-candidate="true">
        <constructor-arg ref="baseHttpSolrClientFactory"/>
        <constructor-arg value="event_id"/>
    </bean>

    <bean class="org.dspace.statistics.GeoIpService" autowire-candidate="true"/>

    <!-- deduplication -->
    <bean class="org.dspace.app.deduplication.service.impl.SolrDedupServiceImpl" id="org.dspace.app.deduplication.service.DedupService"/>

    <!-- audit -->
    <bean id="org.dspace.app.audit.AuditService" class="org.dspace.app.audit.AuditService"/>

    <!-- suggestion service for solr providers -->
    <bean id="org.dspace.app.suggestion.SolrSuggestionStorageService" class="org.dspace.app.suggestion.SolrSuggestionStorageServiceImpl" />

    <!-- oai -->
    <bean id="oaiSolrClientFactory" class="org.dspace.solr.SolrCloudClientFactoryDecorator" autowire-candidate="true">
        <constructor-arg ref="baseHttpSolrClientFactory"/>
        <constructor-arg value="item.handle"/>
    </bean>

    <!-- service that generates geomap filters -->
    <bean id="org.dspace.discovery.SolrGeomapFilterService"
          class="org.dspace.discovery.SolrGeomapFilterService" />
</beans>
